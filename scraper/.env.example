# Copy this to .env and fill in your Audible credentials
AUDIBLE_EMAIL=you@example.com
AUDIBLE_PASSWORD=your_password_here
AUDIBLE_LOCALE=us

# Comma-separated list of regions to scrape (us, ca, uk, au, de, fr, jp)
# auth_setup.py uses AUDIBLE_LOCALE to create the auth file for that region
AUDIBLE_REGIONS=us,ca

# Set to true to show browser window during scraping (dev only)
PLAYWRIGHT_HEADED=false
